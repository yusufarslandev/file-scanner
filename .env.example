# Ollama sunucu adresi (Docker Compose içinde otomatik ayarlıdır)
OLLAMA_BASE_URL=http://localhost:11434

# Frontend API adresi (yerel geliştirme için)
VITE_API_URL=http://localhost:5000

# Tesseract dil verisi dizini (Docker'da otomatik ayarlıdır)
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata

# JWT Secret Key (required for authentication)
JWT_SECRET_KEY=YourSuperSecretKey2026!@#$%^&*()

# LLM Provider API Keys (choose one)
# Options: openai, openrouter, gemini, 9router

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# OpenRouter
OPENROUTER_API_KEY=sk-your-openrouter-key-here

# Gemini
GEMINI_API_KEY=your-gemini-key-here

# 9Router (recommended for this project)
NINEROUTER_API_KEY=your-ninerouter-key-here

# Ollama (local) - optional
OLLAMA_API_KEY=optional-for-ollama

# Database (SQLite)
DATABASE_PATH=./filescanner.db

# Server port
PORT=5000

# CORS origins
CORS_ORIGIN=https://yourdomain.com